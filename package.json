{
  "name": "MessHall",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.7.0",
  "engines": {
    "node": ">=18 <19"
  },
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "postinstall": "node -e \"const fs=require('fs'); if(fs.existsSync('patches') && fs.readdirSync('patches').length){ require('child_process').execSync('npx patch-package', {stdio:'inherit'}); }\""
  },
  "dependencies": {
    "@react-navigation/native": "^7.1.17",
    "@supabase/supabase-js": "^2.56.0",
    "expo": "^52.0.0",
    "expo-build-properties": "~0.13.3",
    "expo-dev-client": "~5.0.20",
    "expo-file-system": "~18.1.11",
    "expo-image-manipulator": "~13.0.6",
    "expo-linking": "~7.0.5",
    "expo-modules-autolinking": "^2.0.0",
    "expo-modules-core": "^2.0.0",
    "expo-share-intent": "3.2.3",
    "expo-system-ui": "^3.0.0",
    "patch-package": "8.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "2.20.2",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "4.4.0",
    "react-native-view-shot": "^4.0.3",
    "react-native-webview": "13.13.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "~5.8.3"
  },
  "overrides": {
    "expo-modules-core": "^2.0.0",
    "expo-modules-autolinking": "^2.0.0"
  }
}

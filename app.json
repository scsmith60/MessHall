{
  "expo": {
    "name": "MessHall",
    "slug": "messhall",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "messhall",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "icon": "./assets/messhall_icon_1024.png",
    "splash": {
      "image": "./assets/messhall_splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0F19"
    },
    "ios": {
      "bundleIdentifier": "com.scsmith60.messhall",
      "supportsTablet": false,
      "infoPlist": { "ITSAppUsesNonExemptEncryption": false }
    },
    "android": {
      "package": "com.scsmith60.messhall",
      "enableEdgeToEdge": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/messhall_icon_1024.png",
        "backgroundColor": "#0B0F19"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "category": ["BROWSABLE", "DEFAULT"],
          "data": [
            { "scheme": "https", "host": "messhall.app" },
            { "scheme": "https", "host": "www.messhall.app" }
          ]
        }
      ]
    },
    "plugins": [
  [
    "expo-share-intent",
    {
      "iosActivationRules": {
        "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
        "NSExtensionActivationSupportsWebPageWithMaxCount": 1,
        "NSExtensionActivationSupportsImageWithMaxCount": 1,
        "NSExtensionActivationSupportsMovieWithMaxCount": 1
      },
      "androidIntentFilters": ["text/*", "image/*"]
    }
  ],
  [
    "expo-build-properties",
    {
      "android": {
        "minSdkVersion": 24,
        "compileSdkVersion": 35,
        "targetSdkVersion": 35,
        "kotlinVersion": "1.9.24",
        "gradleProperties": {
          "android.useAndroidX": "true",
          "android.enableJetifier": "true"
        }
      },
      "ios": { "deploymentTarget": "15.1" }
    }
  ],
  "./plugins/with-assert-compile-sdks",
  "./plugins/with-desugar-libs",
  "./plugins/with-enforce-kotlin"
],
    "experiments": { "typedRoutes": true },
    "extra": {
      "eas": { "projectId": "521a656b-0e37-4ae1-aae2-f4fd552a48b7" },
      "appleApplicationGroup": "group.com.scsmith60.messhall"
    },
    "packagerOpts": { "sourceExts": ["ts", "tsx", "js", "jsx", "json", "cjs"] },
    "updates": { "fallbackToCacheTimeout": 0 },
    "assetBundlePatterns": ["**/*"],
    "owner": "scsmith60"
  }
}
